# Environment Configuration — Copy this file to .env and fill in your values
NODE_ENV=development
PORT=5000

# Database Configuration
# Development: use SQLite → DATABASE_URL=sqlite:./database.sqlite
# Production (Render): use the PostgreSQL connection string from your Render dashboard
DATABASE_URL=sqlite:./database.sqlite

# JWT Configuration — generate a strong secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AI Configuration (OpenRouter)
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# Job Search Configuration (RapidAPI JSearch)
# Get a free API key: https://rapidapi.com/letscrape-6bRBa3QGgNx/api/jsearch/pricing
RAPIDAPI_KEY=your-rapidapi-key-here

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@resumeanalyzer.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Frontend URL (for CORS) — your Vercel deployment URL in production
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging (info for prod, debug for dev)
LOG_LEVEL=debug
